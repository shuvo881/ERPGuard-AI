# Copy to `.env` (already gitignored) and fill in your values.
#   cp .env.example .env

# Required for LLM-formatted responses and the LLM router fallback.
# Without it, the service still runs end-to-end with a deterministic
# JSON formatter.
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI chat model used for formatting / router fallback.
# ERPGUARD_LLM_MODEL=gpt-5

# Optional: 1 (default) persists graph state to data/checkpoints.sqlite
# so sessions resume across process restarts. Set to 0 to use an
# in-memory checkpointer instead.
# ERPGUARD_CHECKPOINT_SQLITE=1
